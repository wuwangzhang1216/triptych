{
  "name": "triptych",
  "version": "0.2.0",
  "description": "Three-model planning-mode debate framework: Claude × Codex × any OpenAI-compatible model (OpenRouter, DeepSeek, Kimi, GLM, Qwen, MiniMax, Groq, Mistral, xAI, ...) cross-review, revise, and synthesize.",
  "license": "MIT",
  "author": {
    "name": "wangzhangwu",
    "email": "wangzhangwu1216@gmail.com"
  },
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "keywords": [
    "llm",
    "multi-agent",
    "planning",
    "claude",
    "codex",
    "openai-compatible",
    "openrouter",
    "deepseek",
    "kimi",
    "moonshot",
    "glm",
    "zhipu",
    "qwen",
    "dashscope",
    "minimax",
    "groq",
    "mistral",
    "grok",
    "anthropic",
    "chatgpt",
    "debate",
    "agent"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "start": "bun src/cli.ts",
    "dev": "bun --watch src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "triptych": "src/cli.ts",
    "pj": "src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.90.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-glob": "3.3.3",
    "openai": "6.34.0",
    "ora": "^8.0.1",
    "turndown": "7.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/turndown": "5.0.6",
    "typescript": "^5.4.0"
  }
}
